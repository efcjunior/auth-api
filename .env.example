MONGODB_URI=mongodb://mongo:27017/auth-api
JWT_ISSUER=http://localhost:8080
JWT_ALLOWED_AUDIENCES=bdi-api

# Local profile uses ephemeral RSA keys. Production must supply PEM keys from a secret store.
# JWT_PUBLIC_KEY=
# JWT_PRIVATE_KEY=

# Optional bootstrap administrator. Used only when no ADMIN user exists.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Enable this only behind a trusted reverse proxy.
AUTH_API_RATE_LIMIT_TRUST_FORWARDED_HEADERS=false
