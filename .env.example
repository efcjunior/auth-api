MONGODB_URI=mongodb://mongo:27017/auth-api
JWT_ISSUER=http://localhost:8080
JWT_ALLOWED_AUDIENCES=bdi-api

# Phase 1 only prepares these values. Token issuing starts in a later phase.
# Production must supply PEM keys from a secret store when JWT issuing is enabled.
# JWT_PUBLIC_KEY=
# JWT_PRIVATE_KEY=

# Bootstrap administrator is prepared for a later phase.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Enable this only behind a trusted reverse proxy.
AUTH_API_RATE_LIMIT_TRUST_FORWARDED_HEADERS=false
